    4b6e:	b5 cf       	rjmp	.-150    	; 0x4ada <ID_Set+0xc>
			else if(KEY.Key == 3 && Cell_ID > 0)  {Cell_ID--; KEY.Key = 0;}				// лӢӨмҡҙлІ„нҠј мқҙл©ҙ IDк°’ к°җмҶҢ
		}
		wdt_reset();							// мӣҢм№ҳлҸ… лҰ¬м…Ӣ
	}
//-------------------------------------------------------------------------------------------------
	ee_write_byte(Cell_ID_Addr, Cell_ID);					// лЎңл“ңм…Җ мқҙл©ҙ ID лҘј EEPROM м—җ м ҖмһҘ
