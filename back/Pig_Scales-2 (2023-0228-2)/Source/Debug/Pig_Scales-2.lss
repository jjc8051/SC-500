void ID_Set(void)								// ID м„Өм •
{
	FND_Value_Data(0, 2, 12);						// FND 0 ~ 2 FND_OFF

	while(SET.Menu && SET.Select)						// л©”лүҙ мҷҖ м„ нғқ мқҙ лӘЁл‘җ 1 мқҙл©ҙ л°ҳліө
