    4894:	b5 cf       	rjmp	.-150    	; 0x4800 <ID_Set+0xc>
			else if(KEY.Key == 3 && Cell_ID > 0)  {Cell_ID--; KEY.Key = 0;}	// лӢӨмҡҙлІ„нҠј мқҙл©ҙ IDк°’ к°җмҶҢ
		}
		wdt_reset();							// мӣҢм№ҳлҸ… лҰ¬м…Ӣ
	}
//-------------------------------------------------------------------------------------------------
