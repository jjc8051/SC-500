    41c2:	90 e0       	ldi	r25, 0x00	; 0
    41c4:	0e 94 5f 0f 	call	0x1ebe	; 0x1ebe <ee_write_byte>
    41c8:	08 95       	ret

000041ca <Loadcell_Set>:
}

