    41b0:	88 23       	and	r24, r24
    41b2:	21 f0       	breq	.+8      	; 0x41bc <ID_Set+0xa2>
    41b4:	80 91 90 4a 	lds	r24, 0x4A90	; 0x804a90 <SET+0x1>
    41b8:	81 11       	cpse	r24, r1
    41ba:	b5 cf       	rjmp	.-150    	; 0x4126 <ID_Set+0xc>
			else if(KEY.Key == 3 && Cell_ID > 0)  {Cell_ID--; KEY.Key = 0;}	// ΈΜνΉγ┤Έ▓ΕΊΛ╝ Ήζ┤Έσ┤ IDΆ░Τ Ά░ΡΉΗΝ
		}
		wdt_reset();							// ΉδΝΉ╣αΈΠΖ ΈουΉΖΜ
	}
//-------------------------------------------------------------------------------------------------
	ee_write_byte(Cell_ID_Addr, Cell_ID);					// ΈκεΈΥεΉΖΑ Ήζ┤Έσ┤ ID Έξ╝ EEPROM ΉΩΡ ΉιΑΉηξ
