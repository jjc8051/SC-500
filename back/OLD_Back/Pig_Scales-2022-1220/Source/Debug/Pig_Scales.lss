	FND_Value_Data(0, 2, 12);						// FND 0 ~ 2 FND_OFF

	while(SET.Menu && SET.Select)						// ΈσΦΈΚ┤ ΉβΑ ΉΕιΊΔζ Ήζ┤ ΈςρΈΣΡ 1 Ήζ┤Έσ┤ Έ░αΈ│╡
