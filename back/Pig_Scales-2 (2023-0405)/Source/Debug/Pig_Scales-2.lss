void Gwid_Set(void)								// АдРЬЦЎ ПўРЬ ID МГСЄ
{
	FND_Value_Data(0, 2, 12);						// FND 0 ~ 2 FND_OFF

	while(SET.Menu && SET.Select)						// ИоДК ПЭ МБХУ РЬ И№ЕЮ 1 РЬИщ ЙнКЙ
