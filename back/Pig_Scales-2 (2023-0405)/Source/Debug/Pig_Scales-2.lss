			else if(KEY.Key == 3 && Gwid > 1)  {Gwid--; KEY.Key = 0;}		// ДйПюЙіЦА РЬИщ ID  0БюСі АЈМв
		}
		wdt_reset();							// ПіФЁЕЖ ИЎМТ
